{
  "name": "invoiceflow-server",
  "version": "1.0.0",
  "description": "InvoiceFlow Backend API",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "seed": "node utils/seedData.js",
    "test": "cross-env NODE_ENV=test DB_NAME=invoiceflow_test jest --runInBand --forceExit --detectOpenHandles",
    "test:verbose": "cross-env NODE_ENV=test DB_NAME=invoiceflow_test jest --runInBand --forceExit --detectOpenHandles --verbose",
    "test:coverage": "cross-env NODE_ENV=test DB_NAME=invoiceflow_test jest --runInBand --forceExit --detectOpenHandles --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "mongoose": "^9.6.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.2",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.15.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
